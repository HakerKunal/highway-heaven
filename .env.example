# Password for the /admin panel. CHANGE THIS before deploying!
ADMIN_PASSWORD=highway@123

# Optional but recommended for production: persistent storage.
# On Vercel: Dashboard -> Storage -> Create "Upstash for Redis" -> connect to project.
# These variables get added automatically. Without them, data resets on redeploys.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ---- Online payments (Razorpay) ----
# Sign up at razorpay.com, complete KYC, then Settings -> API Keys -> Generate.
# Without these, the site simply hides 'Pay now' and uses cash/UPI on delivery.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# ---- Order alerts on your phone (Telegram) ----
# 1) On Telegram, message @BotFather -> /newbot -> copy the token below.
# 2) Send your new bot any message, then open:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  and copy the chat id.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
